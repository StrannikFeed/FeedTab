{
  "manifest_version": 3,
  "name": "FeedTab",
  "version": "1.0.0",
  "description": "Новая вкладка с галереей изображений",
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}